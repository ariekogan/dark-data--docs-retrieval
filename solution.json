    {
      "id": "docs-librarian",
      "name": "Docs Librarian",
      "role": "orchestrator",
      "description": "Entry point. Decomposes questions, runs targeted retrieval, hands off to contract-analyst for deep reasoning.",
      "connectors": [
        "dropbox-mcp",
        "docs-index-mcp",
        "browser-mcp"
      ]
    },
    {
      "id": "contract-analyst",
      "name": "Contract Analyst",
      "role": "worker",
      "description": "Deep multi-hop reasoning over technical/legal documents. Receives research dossiers from the librarian.",
      "connectors": [
        "docs-index-mcp"
      ]
    }
  ],
  "grants": [],
