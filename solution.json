{
  "id": "docs-retrieval",
  "name": "Docs Retrieval",
  "version": "0.5.0",
  "description": "Two-skill orchestrator solution for technical/contract document retrieval, using the cloud-docs platform connector (Dropbox, Google Drive) and docs-index-mcp for corpus retrieval.",
  "orchestrator_skill": "docs-librarian",
  "identity": {
    "actor_types": [],
    "admin_roles": [],
    "default_actor_type": "",
    "default_roles": []
  },
  "skills": [
    {
      "id": "docs-librarian",
      "name": "Docs Librarian",
      "role": "orchestrator",
      "description": "Entry point. Decomposes questions, runs targeted retrieval, hands off to contract-analyst for deep reasoning.",
      "connectors": [
        "cloud-docs",
        "docs-index-mcp"
      ]
    },
    {
      "id": "contract-analyst",
      "name": "Contract Analyst",
      "role": "worker",
      "description": "Deep multi-hop reasoning over technical/legal documents. Receives research dossiers from the librarian.",
      "connectors": [
        "docs-index-mcp"
      ]
    }
  ],
  "grants": [],
  "handoffs": [],
  "routing": {
    "telegram": {
      "default_skill": "docs-librarian",
      "description": "Telegram messages start at the librarian"
    },
    "email": {
      "default_skill": "docs-librarian",
      "description": "Emails start at the librarian"
    },
    "web": {
      "default_skill": "docs-librarian",
      "description": "Web/chat messages start at the librarian"
    }
  },
  "platform_connectors": [
    {
      "id": "docs-index-mcp",
      "required": true
    },
    {
      "id": "cloud-docs",
      "required": true
    },
    {
      "id": "browser-mcp",
      "required": false
    }
  ],
  "ui_plugins": [
    {
      "id": "mcp:browser-mcp:auth-webview",
      "name": "Auth WebView",
      "version": "1.2.0",
      "type": "ui",
      "render": {
        "mode": "adaptive",
        "iframeUrl": "/ui/login-webview/index.html",
        "reactNative": {
          "component": "AuthWebView",
          "bundleUrl": "/api/ui-plugins/mcp%3Abrowser-mcp%3Aauth-webview/bundle.js"
        }
      },
      "capabilities": {
        "webview": true,
        "cookies": true,
        "haptics": true
      },
      "channels": [
        "command"
      ],
      "commands": []
    }
  ],
  "security_contracts": [],
  "connectors": [],
  "_force_redeploy": true
}
