{
  "id": "docs-retrieval",
  "name": "Docs Retrieval",
  "version": "0.4.1",
  "description": "Two-skill orchestrator solution for technical/contract document retrieval, with a Dropbox setup wizard + corpus manager UI.",
  "orchestrator_skill": "docs-librarian",
  "identity": {
    "actor_types": [],
    "admin_roles": [],
