  "policy": {
    "guardrails": {
      "never": [
        "Answer factual content questions without calling docs.search first",
        "Invent file paths, chunk contents, or heading paths",
        "Synthesize a legal/technical interpretation — hand off to contract-analyst",
        "Upload, delete, or modify content without explicit user confirmation"
      ],
      "always": [
        "When the user asks about directory structure, folder contents, 'show files', or similar listing requests, use dropbox.list_folder with path='' for root (or a specific path) — NEVER use dropbox.search with an empty query (Dropbox's search API rejects empty queries with invalid_argument).",
        "Use dropbox.search ONLY when the user provides specific keywords/text to search for. Never pass empty string as the query."
      ]
    }
  },
  "engine": {
    "model": "claude-sonnet-4-20250514",
    "temperature": 0.2,
    "rv2": {
      "max_iterations": 30,
      "iteration_timeout_ms": 45000,
      "allow_parallel_tools": false
    },
    "hlr": {
      "enabled": true,
      "critic": {
        "enabled": true,
        "strictness": "medium"
      },
      "reflection": {
        "enabled": true,
        "depth": "shallow"
      }
    },
    "autonomy": {
      "level": "autonomous"
    }
  },
  "triggers": [
    {
      "id": "auto-sync-dropbox-corpora",
      "type": "schedule",
      "enabled": true,
      "concurrency": 1,
      "every": "PT1H",
      "prompt": "Sync Dropbox-backed corpora. 1) call docs.corpus.list. 2) for each corpus where source_type=='dropbox', call dropbox.index_folder(corpus_id, path: source_config.path, recursive: true, use_cursor: true). 3) report ONLY if total indexed/skipped/failed > 0 across all corpora — otherwise say nothing (silent run). 4) if no dropbox corpora exist, do nothing."
    }
  ],
  "policy.guardrails.never": [
    "Use run_python_script, code execution, or any scripting tool for document retrieval. Document Q&A is handled EXCLUSIVELY via docs.* MCP tools.",
    "Pass a corpus_id that was not returned by docs.corpus.list in THIS job. Corpus ids from previous sessions, memory, or caches are stale — always refetch."
  ],
  "policy.guardrails.always": [
    "When answering any content question about indexed documents, the FIRST tool call must be docs.corpus.list. The SECOND must be docs.search. No other order is acceptable."
  ]
}